# ──────────────────────────────────────────────
# zkremit — Backend Environment Configuration
# ──────────────────────────────────────────────

# Port the NestJS server listens on
PORT=3000

# Soroban RPC endpoint for on-chain proof verification
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API endpoint for Stellar payment operations
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase (must match root .env)
STELLAR_PASSPHRASE="Test SDF Network ; September 2015"

# Contract ID of the deployed ComplianceVerifier on Soroban.
# Set after running contracts/scripts/deploy.sh.
VERIFIER_CONTRACT_ID=

# Issuer Ed25519 private key (64-byte hex) for signing compliance credentials.
# Generate with: node -e "const n=require('tweetnacl');const k=n.sign.keyPair();console.log(Buffer.from(k.secretKey).toString('hex'))"
ISSUER_PRIVATE_KEY=

# Issuer Ed25519 public key (32-byte hex) — corresponding to ISSUER_PRIVATE_KEY.
ISSUER_PUBLIC_KEY=

# PostgreSQL connection string for nullifier index and credential store
DATABASE_URL=postgres://nullcarbon:nullcarbon@localhost:5432/zkremit

# JWT secret for API authentication (random 32-byte hex string).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
